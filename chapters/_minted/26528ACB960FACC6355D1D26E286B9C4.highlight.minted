\PYG{p}{]}

\PYG{c+c1}{\PYGZsh{} For this demonstration, duplicate and vary examples}
\PYG{c+c1}{\PYGZsh{} to reach 50 training samples}
\PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{copy}
\PYG{k}{while} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{train\PYGZus{}data}\PYG{p}{)} \PYG{o}{\PYGZlt{}} \PYG{l+m+mi}{50}\PYG{p}{:}
