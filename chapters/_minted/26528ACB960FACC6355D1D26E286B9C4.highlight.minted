        \PYG{l+s+s2}{\PYGZdq{}Since 51 = 3 * 17, it is not prime.\PYGZdq{}}\PYG{p}{,}
        \PYG{l+s+s2}{\PYGZdq{}No, 51 is not prime. It equals 3 times 17.\PYGZdq{}}
