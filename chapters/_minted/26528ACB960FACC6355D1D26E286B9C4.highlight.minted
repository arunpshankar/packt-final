        \PYG{p}{]}
    \PYG{p}{\PYGZcb{}}

\PYG{c+c1}{\PYGZsh{} Build a dataset with think\PYGZhy{}tag formatted examples}
\PYG{n}{train\PYGZus{}data} \PYG{o}{=} \PYG{p}{[}
    \PYG{n}{make\PYGZus{}example}\PYG{p}{(}
