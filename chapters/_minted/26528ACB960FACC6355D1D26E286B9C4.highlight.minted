\PYG{c+c1}{\PYGZsh{} Helper function to format a single example}
\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{make\PYGZus{}example}\PYG{p}{(}\PYG{n}{question}\PYG{p}{,} \PYG{n}{thinking}\PYG{p}{,} \PYG{n}{answer}\PYG{p}{):}
    \PYG{k}{return} \PYG{p}{\PYGZob{}}
        \PYG{l+s+s2}{\PYGZdq{}messages\PYGZdq{}}\PYG{p}{:} \PYG{p}{[}
