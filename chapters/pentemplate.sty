%% =============================================
%% Codeblock styles
%% @param_1: Lang. Refer: 
%%  {https://www.overleaf.com/learn/latex/Code_Highlighting_with_minted}
%% for a non-exhaustive list of supported lexers.
%% =============================================

\definecolor{codeblock-body}{rgb}{0.98, 0.98, 0.98}
\definecolor{codeblock-border}{rgb}{0.88, 0.88, 0.88}

\renewcommand{\theFancyVerbLine}
    { \textcolor[rgb]{0.25,0.25,0.25}{\ttfamily{\arabic{FancyVerbLine}}} }

\newtcblisting{codeblock}[1][text]
{
    breakable=true,
    nobeforeafter,
    listing engine=minted,
    minted language=#1,
    minted options={
        baselinestretch=1,
        breaklines,
        breaksymbolleft=,
        mathescape,
        numbersep=5mm
    },
    colback=codeblock-body,
    frame hidden,
    sharp corners,
    listing only,
    left=4mm,
    enhanced,
    overlay={
        \begin{tcbclipinterior}
        \fill[codeblock-border] (frame.south west) rectangle ([xshift=2mm]frame.north west);
        \end{tcbclipinterior}
    }
}

\newtcblisting{numberedcodeblock}[1][text]
{
    breakable=true,
    nobeforeafter,
    listing engine=minted,
    minted language=#1,
    minted options={
        baselinestretch=1,
        breaklines,
        breaksymbolleft=,
        mathescape,
        linenos,
        numbersep=4mm
    },
    colback=codeblock-body,
    frame hidden,
    sharp corners,
    listing only,
    left=10mm,
    enhanced,
    overlay={
        \begin{tcbclipinterior}
        \fill[codeblock-border] (frame.south west) rectangle ([xshift=8mm]frame.north west);
        \end{tcbclipinterior}
    }
}


