%% =============================================
%% Default heading and TOC styles
%% =============================================

%% Strike rule for part labels
\newcommand{\createrule}[1][0.4pt]
    { \titlerule*[1pt]{\rule[0.25em]{12pt}{#1}} }

%% Strut for chapter titles
\newcommand{\createstrut}[1]
    { \hrule height #1 width 0pt }


%% Wrap all parts in this environment
\newenvironment{partenv}
{
    \pagestyle{plain}
    \setcounter{secnumdepth}{0}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
    %% TOC format for parts
    \titlecontents{part}
    [0em]
    {\sffamily\setlength{\vspace}{0.25in}\large\bfseries\hspace*{0em}}
    {\sffamily\large\bfseries\partname\enspace\thecontentslabel\hspace*{1pt}:\enspace}
    {\sffamily\large\bfseries}
    {\sffamily\large \enspace\titlerule*[1pc]{\enspace}\contentspage}[\hrule]
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }


%% Wrap all unnumbered but listed parts (Appendices) in this environment
\newenvironment{unnumberedpartenv}
{
    \pagestyle{plain}
    \setcounter{secnumdepth}{-2}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
    %% TOC format for parts
    \titlecontents{part}
    [0em]
    {\sffamily\setlength{\vspace}{0.25in}\large\bfseries\hspace*{0em}}
    {\sffamily\large\bfseries\partname\enspace\thecontentslabel\hspace*{1pt}:\enspace}
    {\sffamily\large\bfseries}
    {\sffamily\large \enspace\titlerule*[1pc]{\enspace}\contentspage}[\hrule]
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }


%% Wrap all chapters in this environment
\newenvironment{chapterenv}
{
    \renewcommand{\chaptertitlename}{\chaptername} 
    \thispagestyle{plain}
    \setcounter{secnumdepth}{0}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
    \pagestyle{chapter}
    %% TOC format for chapters
    \titlecontents{chapter}
    [0em]
    {\sffamily\setlength{\vspace}{0.125in}}
    {\sffamily\normalsize\bfseries\chaptertitlename\enspace\thecontentslabel\hspace*{1pt}:\enspace}
    {\sffamily\normalsize\bfseries}
    {\sffamily\normalsize\bfseries\titlerule*[0.35pc]{\enspace}\contentspage}
    [\hrule\setlength{\vspace}{0.0625in}]
    
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }


%% Wrap all appendix chapters in this environment
\newenvironment{appendixenv}
{
    \thispagestyle{plain}
    \setcounter{secnumdepth}{0}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
    \pagestyle{chapter}
    %% TOC format for appendix
    \titlecontents{chapter}
    [0em]
    {\sffamily\setlength{\vspace}{0.125in}}
    {\sffamily\normalsize\bfseries\appendixname\enspace\thecontentslabel\hspace*{1pt}:\enspace}
    {\sffamily\normalsize\bfseries}
    {\sffamily\normalsize\bfseries\titlerule*[0.35pc]{\enspace}\contentspage}
    [\hrule\setlength{\vspace}{0.0625in}]
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }


%% Wrap all unnumbered but listed chapters (Preface, BM, Index) in this environment
\newenvironment{unnumberedchapterenv}
{
    \renewcommand{\chaptertitlename}{\chaptername} 
    \thispagestyle{plain}
    \setcounter{secnumdepth}{-1}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
    \pagestyle{unnumberedchapter}
    %% TOC format for chapters
    \titlecontents{chapter}
    [0em]
    {\sffamily\setlength{\vspace}{0.125in}}
    {\sffamily\normalsize\bfseries\chaptertitlename\enspace\thecontentslabel\hspace*{1pt}:\enspace}
    {\sffamily\normalsize\bfseries}
    {\sffamily\normalsize\bfseries\titlerule*[0.35pc]{\enspace}\contentspage}
    [\hrule\setlength{\vspace}{0.0625in}]
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }


%% Wrap all unnumbered and unlisted chapters (FM) in this environment
\newenvironment{unlistedchapterenv}
{
    \renewcommand{\chaptertitlename}{\chaptername} 
    \pagestyle{plain}
    \setcounter{secnumdepth}{-2}
    \begin{justify}
    \setlength\parindent{0pt}
    \setlength{\parskip}{0.75em minus 0.25em}
    \normalsize\rmfamily
}
{ \clearpage{\thispagestyle{empty}\cleardoublepage}\end{justify} }

%% TOC format for sections
\titlecontents{section}
[0em]
{\LibertinusSerifSB}{\thecontentslabel}{}
{\enspace\titlerule*[0.35pc]{.}\enspace\contentspage}

\titlecontents{subsection}
[2.3em]
{}{\thecontentslabel}{}
{\enspace•\enspace\thecontentspage}

\titlecontents{subsubsection}
[4.6em]
{}{\itshape\thecontentslabel}{\itshape}
{\enspace•\enspace\thecontentspage}


%% Title format for parts
\titleformat{\part}[display]
    {\filcenter\sffamily\HUGE\fontseries{sb}\selectfont\scshape\setstretch{1.1}}
    {\Huge\textbf{\createrule[0.4pt] Part \thepart \createrule[0.4pt]}}
    {0em}{#1}
    
%% Title format for unnumbered parts
\titleformat{name=\part,numberless}[hang]
    {\filcenter\sffamily\HUGE\fontseries{sb}\selectfont\scshape\setstretch{1.1}}
    {}
    {0em}{\createrule[0.4pt] #1 \createrule[0.4pt]}[]


%% Title format for chapters
\titleformat{\chapter}[display]
    {\sffamily\HUGE\fontseries{sb}\selectfont\setstretch{1.1}\raggedright}
    {\createstrut{96pt}\setlength{\parskip}{0pt}\setlength{\vspace}{0pt}\fontsize{84}{0}\fontseries{sb}\selectfont{\thechapter}}
    {0.5em}{#1}

%% Title format for unnnumbered chapters
\titleformat{name=\chapter,numberless}[display]
    {\filleft\sffamily\HUGE\fontseries{sb}\selectfont\setstretch{1.1}\raggedleft}{}
    {0.5em}{#1}


%% Title formats for heading levels
\titleformat{\section}
    {\sffamily\LARGE\bfseries\setstretch{1.1}\raggedright}{\thesection}{1em}{#1}
\titleformat{\subsection}
    {\sffamily\Large\bfseries\setstretch{1.1}\raggedright}{\thesubsection}{1em}{#1}
\titleformat{\subsubsection}
    {\sffamily\large\bfseries\setstretch{1.1}\raggedright}{\thesubsubsection}{1em}{#1}
\titleformat{\paragraph}
    {\sffamily\normalsize\bfseries\setstretch{1.1}\raggedright}{\theparagraph}{1em}{#1}
\titleformat{\subparagraph}
    {\sffamily\normalsize\fontseries{sb}\setstretch{1.1}\raggedright}{\thesubparagraph}{1em}{#1}

\titlespacing*{\section}{0pt}{15pt minus 3pt}{1pt minus 0.25pt}
\titlespacing*{\subsection}{0pt}{15pt minus 3pt}{1pt minus 0.25pt}
\titlespacing*{\subsubsection}{0pt}{12pt}{1pt minus 0.25pt}
\titlespacing*{\paragraph}{0pt}{12pt}{1pt minus 0.25pt}
\titlespacing*{\subparagraph}{0pt}{12pt}{1pt minus 0.25pt}


%% =============================================
%% Front Matter
%% =============================================

%% If the parameter passed is `1`, initialize `\theedition` to an empty string
%% Else, convert the number to it's ordinal string form, prepend it to ` Edition`, and initialize `\theedition` with this

\renewcommand{\title}[1]
{
    %% titlesec redef's `thetitle`. Ugly workaround for this
    \expandafter\newcommand\csname thetitle\endcsname{#1}
    \expandafter\newcommand\csname thebooktitle\endcsname{#1}
}

\renewcommand{\date}[1]
{
    \DTMsavedate{uploaddate}{#1}
}

%\def\thedate {\DTMusedate{uploaddate}}

\newcommand{\edition}[1]
{
    \ifdim#1pt=1pt
        \expandafter\newcommand\csname theedition\endcsname{}
    \else%
        \expandafter\newcommand\csname theedition\endcsname{\Ordinalstringnum{#1} Edition}
        
    \fi%
    \expandafter\newcommand\csname theeditionint\endcsname{#1}
}

%% Initialize `\thesubtitle` with the passed parameter
\newcommand{\subtitle}[1]
{
    \expandafter\newcommand\csname thesubtitle\endcsname{#1}
}

%% Replace commas in `\theauthor` to newline
\newcommand{\sepauthors}[1]
{
    \readlist*\authorlist{#1}
    
    \foreachitem\x\in\authorlist[]
    {
        \x\setlength{\parskip}{0.125in}\par
    }
}

\newcommand{\uploadcount}[1]
{
    \expandafter\newcommand\csname theuploadcount\endcsname{#1}
}

\newcommand{\isbnten}[1]
{
    \expandafter\newcommand\csname theisbnten\endcsname{#1}
    \StrDel{#1}{-}[\temp]
    \def\revurl{\expandafter\url\expandafter{https://packt.link/r/\temp}}
    \def\revlink{\expandafter{https://packt.link/r/\temp}}
}

\newcommand{\isbnthirteen}[1]
{
    \expandafter\newcommand\csname theisbnthirteen\endcsname{#1}
}


\newcommand{\unhyphenate}[1]{
    \StrDel{#1}{-}[\temp]
    \ignorespaces\temp\ignorespaces
}

%% Returns the correct collective form; 
%% "author" or "authors"
\newcommand{\autcolform}
{
    \readlist*\authorlist{\theauthor}
    \ifdim\authorlistlen pt>1pt \setlength{\hspace}{-.5em}authors%
    \else \setlength{\hspace}{-.5em}author%
    \fi%
}

\newcommand{\fulltitle}
{
    \ifdim\theeditionint pt>1pt \thebooktitle, \theedition%
    \else \thebooktitle%
    \fi%
}

\newcommand{\prodref}
{\ignorespaces
    \theuploadcount\setlength{\hspace}{-0.8em}
    \DTMsetdatestyle{ddmmyy}\unhyphenate{\Today}\DTMsetdatestyle{ddmmyyyy}
}


