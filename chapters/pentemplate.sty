\RequirePackage[paperwidth=7.5in, paperheight=9.25in, left=1in, right=1in, top=0.875in, bottom=0.875in]{geometry}

%% For headers and Footers

\RequirePackage[explicit, newparttoc, pagestyles]{titlesec} %% explicit, 

%% Remove unwanted page breaks added by `\chapter` and `\part`.
%% These can be added as needed in the environment.
\titleclass{\part}{straight}
\titleclass{\chapter}{straight}

\renewpagestyle{plain}
{
    \sethead[][][]
    {}{}{}
    \setfoot[][][]
    {}{}{}
}

\newpagestyle{chapter}
{
    \sethead[\small\thepage][][\small\textit{\chaptertitle}] % even
    {\small\textit{\chaptertitlename\space\thechapter}}{}{\small\thepage} % odd
    \renewcommand{\makeheadrule}{\rule[-.3\baselineskip]{\linewidth}{0.4pt}}
}

\newpagestyle{unnumberedchapter}
{
    \sethead[\small\thepage][][\small\textit{\chaptertitle}] % even
    {\small\textit{\chaptertitle}}{}{\small\thepage} % odd
    \renewcommand{\makeheadrule}{\rule[-.3\baselineskip]{\linewidth}{0.4pt}}
}

\newpagestyle{bibliography}
{
    \sethead[\small\thepage][][\small\textit{Bibliography}] % even
    {\small\textit{Bibliography}}{}{\small\thepage} % odd
    \renewcommand{\makeheadrule}{\rule[-.3\baselineskip]{\linewidth}{0.4pt}}
}


